{
  "routes": [
    {
      "stream": "document.artifacts",
      "event_type": "*",
      "skill": "echo",
      "publish_stream": "inference-events",
      "publish_event_type": "flint.strike.result"
    },
    {
      "stream": "document.vectorize",
      "event_type": "*",
      "skill": "passthrough",
      "publish_stream": "inference-events",
      "publish_event_type": "flint.vectorize.seen"
    },
    {
      "stream": "document.training",
      "event_type": "*",
      "skill": "document_fanout",
      "publish_stream": "pipeline.helox-training.structured",
      "publish_event_type": "flint.document.fanout"
    },
    {
      "stream": "pipeline.pressure.events",
      "event_type": "*",
      "skill": "pressure_tag",
      "publish_stream": "pipeline.metrics",
      "publish_event_type": "flint.pressure.tagged"
    }
  ]
}
